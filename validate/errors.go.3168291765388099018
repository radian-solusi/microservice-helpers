package validate

import (
	"errors"
	"fmt"
	"strings"

	"github.com/go-playground/validator/v10"
)

// FormatValidationError converts the first validator error to the established
// user-facing message. Non-validation errors return "Invalid input data".
func FormatValidationError(err error) string {
	if err == nil {
		return ""
	}
	var validationErrs validator.ValidationErrors
	if errors.As(err, &validationErrs) && len(validationErrs) > 0 {
		firstErr := validationErrs[0]
		field := toFriendlyFieldName(firstErr.Field())
		param := firstErr.Param()
		switch firstErr.Tag() {
		case "required":
			return fmt.Sprintf("%s is required", field)
		case "email":
			return fmt.Sprintf("%s must be a valid email address", field)
		case "min":
			return fmt.Sprintf("%s must be at least %s characters", field, param)
		case "max":
			return fmt.Sprintf("%s must not exceed %s characters", field, param)
		case "eqfield":
			return fmt.Sprintf("%s must match %s", field, toFriendlyFieldName(param))
		case "required_without":
			return fmt.Sprintf("Either %s or %s is required", field, toFriendlyFieldName(param))
		case "oneof":
			return fmt.Sprintf("%s must be one of: %s", field, param)
		case "gt":
			return fmt.Sprintf("%s must be greater than %s", field, param)
		case "gte":
			return fmt.Sprintf("%s must be greater than or equal to %s", field, param)
		case "lt":
			return fmt.Sprintf("%s must be less than %s", field, param)
		case "lte":
			return fmt.Sprintf("%s must be less than or equal to %s", field, param)
		default:
			return fmt.Sprintf("%s is invalid", field)
		}
	}
	return "Invalid input data"
}

// FormatValidationErrorFields converts validator errors into a field-keyed map,
// one entry per invalid field.
func FormatValidationErrorFields(err error) map[string]string {
	fields := map[string]string{}
	if err == nil {
		return fields
	}
	var validationErrs validator.ValidationErrors
	if !errors.As(err, &validationErrs) {
		return fields
	}
	for _, fe := range validationErrs {
		fields[fe.Field()] = FormatValidationError(validator.ValidationErrors{fe})
	}
	return fields
}

func toFriendlyFieldName(fieldName string) string {
	if fieldName == "" {
		return ""
	}
	fieldName = strings.ReplaceAll(fieldName, "_", " ")
	var result strings.Builder
	for i, char := range fieldName {
		if i > 0 && char >= 'A' && char <= 'Z' {
			result.WriteRune(' ')
		}
		result.WriteRune(char)
	}
	return strings.ToLower(result.String())
}