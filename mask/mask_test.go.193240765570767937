	cases := []struct {
		name string
		in   string
		want string
	}{
		{"id mobile", "+6281234567890", "+62 8** **** *890"},
		{"id mobile shorter", "+628123456", "+62 8** **** *456"},
		{"id mobile with spaces", "+62 812 3456 7123", "+62 8** **** *123"},
		{"empty", "", ""},
		{"malformed no plus", "081234567890", "***"},
		{"malformed too short", "+62", "***"},
		{"malformed letters", "+62abc", "***"},
	}
	for _, c := range cases {
		t.Run(c.name, func(t *testing.T) {
			if got := MaskPhone(c.in); got != c.want {
				t.Errorf("MaskPhone(%q) = %q, want %q", c.in, got, c.want)
			}
		})
	}
}

