func TestMaskByKey(t *testing.T) {
	cases := []struct {
		key, val, want string
	}{
		{"email", "john.doe@example.com", "j***@example.com"},
		{"recipient_email", "k@mail.example.id", "k***@mail.example.id"},
		{"to", "a@b.co.id", "a***@b.co.id"},
		{"phone", "+6281234567890", "+62 8** **** *890"},
		{"msisdn", "+6281234567890", "+62 8** **** *890"},
		{"recipient_phone", "+628123456", "+62 8** **** *456"},
		{"status", "delivered", "delivered"},
		{"template_key", "otp_login", "otp_login"},
	}
	for _, c := range cases {
		if got := MaskByKey(c.key, c.val); got != c.want {
			t.Errorf("MaskByKey(%q,%q) = %q, want %q", c.key, c.val, got, c.want)
		}
	}
}

func TestMask_NoPanic(t *testing.T) {
	inputs := []string{"", "@", "+", "  ", "@@@", "++++", "\x00", "a@b@c"}
	for _, in := range inputs {
		_ = MaskEmail(in)
		_ = MaskPhone(in)
		_ = MaskOTPRef(in)
	}
}