package mask

import "testing"

func TestMaskEmail(t *testing.T) {
	cases := []struct {
		name string
		in   string
		want string
	}{
		{"well-formed", "john.doe@example.com", "j***@example.com"},
		{"single-char local", "a@example.com", "a***@example.com"},
		{"subdomain", "k@mail.example.co.id", "k***@mail.example.co.id"},
		{"empty", "", ""},
		{"malformed no at", "not-an-email", "***"},
		{"malformed no domain dot", "user@localhost", "***"},
		{"malformed empty local", "@example.com", "***"},
		{"malformed trailing at", "user@", "***"},
	}
	for _, c := range cases {
		t.Run(c.name, func(t *testing.T) {
			if got := MaskEmail(c.in); got != c.want {
				t.Errorf("MaskEmail(%q) = %q, want %q", c.in, got, c.want)
			}
		})
	}
}

