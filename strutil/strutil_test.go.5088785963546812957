package strutil

import "testing"

func ptr[T any](v T) *T { return &v }

func TestSlugify(t *testing.T) {
	cases := []struct{ in, want string }{
		{"Hello World", "hello-world"},
		{"a--b__c", "a-b-c"},
		{"  Spaced  Out  ", "spaced-out"},
		{"Ünïcode & symbols!", "ncode-symbols"},
		{"---edge---", "edge"},
		{"", ""},
	}
	for _, c := range cases {
		if got := Slugify(c.in); got != c.want {
			t.Errorf("Slugify(%q) = %q, want %q", c.in, got, c.want)
		}
	}
}

func TestContainsSubstr(t *testing.T) {
	if !ContainsSubstr("hello", "ell") {
		t.Error("expected true")
	}
	if ContainsSubstr("hello", "xyz") {
		t.Error("expected false")
	}
}

func TestContains(t *testing.T) {
	list := []string{"a", "b", "c"}
	if !Contains(list, "b") {
		t.Error("expected true")
	}
	if Contains(list, "z") {
		t.Error("expected false")
	}
}

func TestInt64ToString(t *testing.T) {
	if Int64ToString(-42) != "-42" {
		t.Error("bad format")
	}
}

func TestParseInt64(t *testing.T) {
	cases := []struct {
		in      string
		want    int64
		wantErr bool
	}{
		{"123", 123, false},
		{"-7", -7, false},
		{" 12", 0, true},
		{"", 0, true},
		{"abc", 0, true},
		{"99999999999999999999999", 0, true},
	}
	for _, c := range cases {
		got, err := ParseInt64(c.in)
		if (err != nil) != c.wantErr {
			t.Errorf("ParseInt64(%q) err = %v, wantErr %v", c.in, err, c.wantErr)
		}
		if err == nil && got != c.want {
			t.Errorf("ParseInt64(%q) = %d, want %d", c.in, got, c.want)
		}
	}
}

func TestParseInt64Default(t *testing.T) {
	if ParseInt64Default("bad", 5) != 5 {
		t.Error("expected default")
	}
	if ParseInt64Default("9", 5) != 9 {
		t.Error("expected parsed")
	}
}

func TestStringValue(t *testing.T) {
	if StringValue(nil) != "" {
		t.Error("nil should be empty")
	}
	if StringValue(ptr("x")) != "x" {
		t.Error("bad deref")
	}
}

func TestBoolString(t *testing.T) {
	if BoolString(nil) != "" {
		t.Error("nil should be empty")
	}
	if BoolString(ptr(true)) != "true" {
		t.Error("bad true")
	}
	if BoolString(ptr(false)) != "false" {
		t.Error("bad false")
	}
}

func TestDefaultValue(t *testing.T) {
	if DefaultValue(nil, "d") != "d" {
		t.Error("nil should default")
	}
	if DefaultValue(ptr(""), "d") != "d" {
		t.Error("empty should default")
	}
	if DefaultValue(ptr("v"), "d") != "v" {
		t.Error("should keep value")
	}
}

func TestFormatSize(t *testing.T) {
	cases := []struct {
		in   int64
		want string
	}{
		{512, "512 B"},
		{1024, "1.0 KiB"},
		{1024 * 1024, "1.0 MiB"},
		{1024 * 1024 * 1024, "1.0 GiB"},
	}
	for _, c := range cases {
		if got := FormatSize(c.in); got != c.want {
			t.Errorf("FormatSize(%d) = %q, want %q", c.in, got, c.want)
		}
	}
}

func TestRandomLabel(t *testing.T) {
	got, err := RandomLabel("id_", 10)
	if err != nil {
		t.Fatalf("unexpected err: %v", err)
	}
	if len(got) != 13 || got[:3] != "id_" {
		t.Errorf("bad label: %q", got)
	}
	for _, r := range got[3:] {
		if !((r >= 'a' && r <= 'z') || (r >= 'A' && r <= 'Z') || (r >= '0' && r <= '9')) {
			t.Errorf("invalid char %q in %q", r, got)
		}
	}
	if _, err := RandomLabel("x", -1); err == nil {
		t.Error("expected error for negative length")
	}
}

func TestExtractIPFromMetadata(t *testing.T) {
	valid := `{"ip_address":"192.0.2.1"}`
	missing := `{"other":"x"}`
	bad := `{not json`
	empty := ""
	cases := []struct {
		in   *string
		want string
	}{
		{nil, ""},
		{&empty, ""},
		{&bad, ""},
		{&missing, ""},
		{&valid, "192.0.2.1"},
	}
	for _, c := range cases {
		if got := ExtractIPFromMetadata(c.in); got != c.want {
